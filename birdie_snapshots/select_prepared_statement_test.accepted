---
version: 1.4.1
title: select_prepared_statement_test
file: ./test/cake_test/select_test.gleam
test_name: select_prepared_statement_test
---
#(
  PreparedStatement(
    "$",
    "SELECT name, $1, age, age AS years_since_birth FROM cats",
    [StringParam("hello")],
    1,
    Postgres,
  ),
  PreparedStatement(
    "?",
    "SELECT name, ?1, age, age AS years_since_birth, ?2, ?3, ?4 FROM cats",
    [
      StringParam("hello"),
      BoolParam(True),
      FloatParam(1.0),
      IntParam(1),
    ],
    4,
    Sqlite,
  ),
  PreparedStatement(
    "?",
    "SELECT name, ?, age, age AS years_since_birth, ?, ? FROM cats",
    [
      StringParam("hello"),
      FloatParam(1.0),
      IntParam(1),
    ],
    3,
    Maria,
  ),
  PreparedStatement(
    "?",
    "SELECT name, ?, age, age AS years_since_birth, ?, ? FROM cats",
    [
      StringParam("hello"),
      FloatParam(1.0),
      IntParam(1),
    ],
    3,
    Mysql,
  ),
)
