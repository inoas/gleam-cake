---
version: 1.4.1
title: date_pog_test
file: ./test/cake_test/date_test.gleam
test_name: date_pog_test
---
SelectQuery(Select(
  SelectAll,
  NoSelects,
  FromTable("cats"),
  NoJoins,
  OrWhere([
    WhereComparison(
      WhereColumnValue("birthday"),
      Equal,
      WhereParamValue(DateParam(Date(
        2016,
        February,
        19,
      ))),
    ),
    WhereBetween(
      WhereColumnValue("birthday"),
      WhereParamValue(DateParam(Date(
        2021,
        April,
        12,
      ))),
      WhereParamValue(DateParam(Date(
        2021,
        April,
        14,
      ))),
    ),
  ]),
  NoGroupBy,
  NoWhere,
  NoOrderBy,
  NoLimit,
  NoOffset,
  NoEpilog,
  NoComment,
))
