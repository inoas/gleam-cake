#(
  PreparedStatement(
    "$",
    "INSERT INTO cats (name, age) VALUES (LOWER($1), $2) RETURNING name, age",
    [StringParam("FELIX"), IntParam(2)],
    2,
    Postgres,
  ),
  PreparedStatement(
    "?",
    "INSERT INTO cats (name, age) VALUES (LOWER(?1), ?2) RETURNING name, age",
    [StringParam("FELIX"), IntParam(2)],
    2,
    Sqlite,
  ),
  PreparedStatement(
    "?",
    "INSERT INTO cats (name, age) VALUES (LOWER(?), ?)",
    [StringParam("FELIX"), IntParam(2)],
    2,
    Maria,
  ),
  PreparedStatement(
    "?",
    "INSERT INTO cats (name, age) VALUES (LOWER(?), ?)",
    [StringParam("FELIX"), IntParam(2)],
    2,
    Mysql,
  ),
)
