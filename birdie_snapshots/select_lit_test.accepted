SelectQuery(Select(
  SelectAll,
  Selects([
    SelectColumn("name"),
    SelectParam(BoolParam(True)),
    SelectParam(FloatParam(1.0)),
    SelectParam(IntParam(1)),
    SelectParam(StringParam("hello")),
    SelectFragment(FragmentLiteral("age")),
    SelectAlias(
      SelectColumn("age"),
      "years_since_birth",
    ),
  ]),
  FromTable("cats"),
  NoJoins,
  NoWhere,
  NoGroupBy,
  NoWhere,
  NoOrderBy,
  NoLimit,
  NoOffset,
  NoEpilog,
  NoComment,
))
